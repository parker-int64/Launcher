import os
import shutil
from pathlib import Path

Import('env')
with open(env['PROJECT_TOOL_S']) as f:
    exec(f.read())

cpp_httplib = wget_github("https://github.com/yhirose/cpp-httplib.git")
applaunch_lvgl_dir = ADir('../../APPLaunch/main/lvgl')

SRCS = Glob('src/*.c*')
SRCS += append_srcs_dir(ADir('ui'))

INCLUDE = [ADir('.'), ADir('include'), ADir('ui'), cpp_httplib, applaunch_lvgl_dir]
PRIVATE_INCLUDE = []
REQUIREMENTS = ['cp0_lvgl', 'lvgl_component', 'pthread', 'Sigslot', 'eventpp', 'RadioLib', 'ssl', 'crypto']
STATIC_LIB = []
DYNAMIC_LIB = []
DEFINITIONS = ['-DCPPHTTPLIB_OPENSSL_SUPPORT']
DEFINITIONS_PRIVATE = []
LDFLAGS = []
LINK_SEARCH_PATH = []
STATIC_FILES = []

PROJECT_ROOT = os.path.abspath(os.path.join(os.getcwd(), ".."))
ZCLAW_STATIC_ROOT = os.path.join(PROJECT_ROOT, "APPLaunch")
APPLAUNCH_STATIC_ROOT = os.path.abspath(os.path.join(PROJECT_ROOT, "..", "APPLaunch", "APPLaunch"))
STAGED_STATIC_ROOT = os.path.abspath(os.path.join("build", "static"))
STAGED_APPLAUNCH = os.path.join(STAGED_STATIC_ROOT, "APPLaunch")


def stage_zclaw_static_files():
    if os.path.exists(STAGED_APPLAUNCH):
        shutil.rmtree(STAGED_APPLAUNCH)
    shutil.copytree(ZCLAW_STATIC_ROOT, STAGED_APPLAUNCH)
    dst_fonts = os.path.join(STAGED_APPLAUNCH, "share", "font")
    os.makedirs(dst_fonts, exist_ok=True)
    shutil.copy2(
        os.path.join(APPLAUNCH_STATIC_ROOT, "share", "font", "AlibabaPuHuiTi-3-55-Regular.ttf"),
        os.path.join(dst_fonts, "AlibabaPuHuiTi-3-55-Regular.ttf"),
    )


stage_zclaw_static_files()
STATIC_FILES += [(STAGED_APPLAUNCH, "APPLaunch")]

lvgl_component = list(filter(lambda x: x['target'] == 'lvgl_component', env['COMPONENTS']))[0]
toolchain_sysroot = os.environ.get('CONFIG_TOOLCHAIN_SYSROOT', '') or '/'

# Keep ZClaw's text rendering aligned with APPLaunch: its FreeType override
# adds a 1-bit glyph mode whose A8 output contains only fully transparent or
# fully opaque pixels.
local_lvgl_override_srcs = Glob('../../APPLaunch/main/lvgl/lv_freetype*.c')
local_lvgl_override_names = set(Path(str(src)).name for src in local_lvgl_override_srcs)
lvgl_component['SRCS'] = [
    src for src in lvgl_component['SRCS']
    if Path(str(src)).name not in local_lvgl_override_names
]
lvgl_component['SRCS'] += local_lvgl_override_srcs
lvgl_component['PRIVATE_INCLUDE'] = [
    applaunch_lvgl_dir,
    ADir('../../../SDK/github_source/lvgl/lvgl_9_5/lvgl/src/libs/freetype'),
] + lvgl_component['PRIVATE_INCLUDE']

if 'CONFIG_V9_5_LV_USE_SDL' in os.environ:
    lvgl_component['REQUIREMENTS'] += ['SDL2']
    lvgl_component['INCLUDE'] += ['/usr/include/SDL2']
    lvgl_component['DEFINITIONS'] += ['-D_REENTRANT']

if 'CONFIG_V9_5_LV_USE_FREETYPE' in os.environ:
    lvgl_component['REQUIREMENTS'] += ['freetype']
    lvgl_component['INCLUDE'] += [
        f"{os.path.join(toolchain_sysroot, 'usr', 'include', 'freetype2')}",
        f"{os.path.join(toolchain_sysroot, 'usr', 'include', 'libpng16')}",
    ]

env['COMPONENTS'].append({
    'target': env['PROJECT_NAME'],
    'SRCS': SRCS,
    'INCLUDE': INCLUDE,
    'PRIVATE_INCLUDE': PRIVATE_INCLUDE,
    'REQUIREMENTS': REQUIREMENTS,
    'STATIC_LIB': STATIC_LIB,
    'DYNAMIC_LIB': DYNAMIC_LIB,
    'DEFINITIONS': DEFINITIONS,
    'DEFINITIONS_PRIVATE': DEFINITIONS_PRIVATE,
    'LDFLAGS': LDFLAGS,
    'LINK_SEARCH_PATH': LINK_SEARCH_PATH,
    'STATIC_FILES': STATIC_FILES,
    'REGISTER': 'project',
})
